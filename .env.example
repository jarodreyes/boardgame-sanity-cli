# Copy to .env and fill in values. Never commit .env (see README).
# Scripts load .env automatically via dotenv (no need for node --env-file).

# Sanity — from sanity.config.ts and sanity.io/manage → API → Tokens
SANITY_PROJECT_ID=
SANITY_API_TOKEN=

# BoardGameGeek — boardgamegeek.com/applications → token (Bearer for XML API)
BGG_API_TOKEN=

# After Studio Agent Context doc exists — paste MCP URL from the document
SANITY_CONTEXT_MCP_URL=

# Viewer token (read-only) for MCP — separate from SANITY_API_TOKEN
SANITY_API_READ_TOKEN=

# Optional — Agent Insights (@sanity/agent-context/ai-sdk): Editor token to save conversations
# (not the MCP Viewer token). Same project as SANITY_PROJECT_ID. See docs/agent-context.md
SANITY_INSIGHTS_WRITE_TOKEN=
# Optional override for the Agent Insights dashboard (default: bgg-agent-cli)
# SANITY_INSIGHTS_AGENT_ID=
# Optional if not "production"
# SANITY_DATASET=production

# OpenAI — platform.openai.com API keys
OPENAI_API_KEY=
